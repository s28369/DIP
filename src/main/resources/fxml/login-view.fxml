<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.fleetmanagement.controller.LoginController"
      alignment="CENTER" 
      spacing="15" 
      style="-fx-background-color: #f4f4f4;">
    
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>
    
    <!-- Nagłówek -->
    <Label text="System Zarządzania Flotą" 
           style="-fx-text-fill: #2c3e50;">
        <font>
            <Font name="System Bold" size="24"/>
        </font>
    </Label>
    
    <Label text="Logowanie" 
           style="-fx-text-fill: #34495e;">
        <font>
            <Font size="16"/>
        </font>
    </Label>
    
    <!-- Pole nazwy użytkownika -->
    <VBox spacing="5">
        <Label text="Nazwa użytkownika:" 
               style="-fx-text-fill: #2c3e50;">
            <font>
                <Font size="12"/>
            </font>
        </Label>
        <TextField fx:id="usernameField" 
                   promptText="Wprowadź nazwę użytkownika"
                   prefWidth="300"
                   style="-fx-background-radius: 5; -fx-border-radius: 5;"/>
    </VBox>
    
    <!-- Pole hasła -->
    <VBox spacing="5">
        <Label text="Hasło:" 
               style="-fx-text-fill: #2c3e50;">
            <font>
                <Font size="12"/>
            </font>
        </Label>
        <PasswordField fx:id="passwordField" 
                       promptText="Wprowadź hasło"
                       prefWidth="300"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;"/>
    </VBox>
    
    <!-- Przycisk logowania -->
    <Button text="Zaloguj" 
            onAction="#handleLogin"
            prefWidth="300"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5;">
        <font>
            <Font name="System Bold" size="14"/>
        </font>
    </Button>
    
    <!-- Informacje testowe -->
    <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
        <Label text="Dane testowe:" 
               style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;">
            <font>
                <Font size="11"/>
            </font>
        </Label>
        <Label text="Administrator: admin / admin123" 
               style="-fx-text-fill: #7f8c8d;">
            <font>
                <Font size="10"/>
            </font>
        </Label>
        <Label text="Logistyk: logistyk / logistyk123" 
               style="-fx-text-fill: #7f8c8d;">
            <font>
                <Font size="10"/>
            </font>
        </Label>
    </VBox>
    
</VBox>
